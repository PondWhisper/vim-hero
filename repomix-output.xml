<file path="src/types/level.ts">
// ─── Shared engine types — consumed by App.tsx and src/config/levels.ts ──────

export type VimMode = 'normal' | 'insert' | 'visual' | 'replace';

// Encodes Vim-command semantics for dynamic ghost-cursor and validate().
//   LINE_END_APPEND      → A: col = lineText.length   (1 past last char, Insert pos)
//   LINE_END_NORMAL      → $: col = lineText.length-1 (on last char, Normal pos)
//   LINE_FIRST_NON_BLANK → I: col = index of first non-whitespace char
//   FIXED                → hardcoded column (fixedCol arg)
export type TargetColAlgorithm =
  | 'LINE_END_APPEND'
  | 'LINE_END_NORMAL'
  | 'LINE_FIRST_NON_BLANK'
  | 'FIXED';

export interface TargetAction {
  colAlgorithm: TargetColAlgorithm;
  targetRow:    number;
  expectedMode: VimMode;
  fixedCol?:    number;
}

// Anchor-text based target — stays correct even when the player inserts/deletes
// lines above the target.  The ghost cursor field re-resolves its physical
// position on every doc change by searching for anchorText in the document.
export interface SemanticWaypoint {
  anchorText:    string;
  anchorOffset:  number;
  colAlgorithm?: TargetColAlgorithm;
  fixedCol?:     number;
}

// What ghostCursorField stores internally.
//   semantic → auto re-resolves on every doc change (drift-proof)
//   fixed    → uses absolute row/col (may drift with o/O)
export type StoredGhostTarget =
  | ({ kind: 'semantic' } & SemanticWaypoint)
  | { kind: 'fixed'; row: number; col: number }
  | null;

export interface EditorSnapshot {
  line:      number;  // 0-indexed
  col:       number;  // 0-indexed
  code:      string;
  lineCount: number;
}

export interface VimCommand {
  key:       string;   // displayed in <kbd>
  desc:      string;   // short Chinese description
  category?: string;   // grouping label
}

// ── Engine v2 extension types ─────────────────────────────────────────────────

/**
 * Keys pulled from COMMAND_REGISTRY (src/engine/commands.ts).
 * In LevelConfig: takes priority over inline `commands`; both are merged by
 * CommandSidebar (registry entries listed first).
 */
export type CommandKeys = string[];

/**
 * Where the real (vim) cursor should be placed when the level loads.
 * Row and col are 0-indexed. If omitted the cursor stays at (0, 0).
 */
export interface InitialCursor {
  row: number;
  col: number;
}
</file>

