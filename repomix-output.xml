  cursor:  { row: 0, col: 0 },
  entropy: 0,
  done:    false,
};

// ─── Action Creators ──────────────────────────────────────────────────────────

export const moveCursorAction = (pos: CursorPos) => ({
  type:    'MOVE_CURSOR' as const,
