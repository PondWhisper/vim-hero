/* ─── Reset ─────────────────────────────────────────────────────────────── */
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body, #root {
  height: 100%;
  overflow: hidden;
  background: #0d0d0d;
  font-family: 'Quicksand', 'Inter', 'Noto Sans SC', system-ui, -apple-system, sans-serif;
  color: #d4d4d4;
}

/* ─── Root Layout (100 vh, flex column) ──────────────────────────────────── */
.app {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  background: #0d0d0d;
}

/* ─── Editor Container ───────────────────────────────────────────────────── */
.editor-container {
  height: 100%;      /* Panel controls the size; we just fill it */
  overflow: hidden;
  border-bottom: 1px solid #222;
  position: relative;
  display: flex;     /* make direct child (.cm-editor wrapper) fill the space */
  flex-direction: column;
  align-items: stretch;      /* never center children horizontally */
  text-align: left;          /* prevent any ancestor center leaking in */
  transition: box-shadow 0.2s ease;
}

/* Insert mode: breathing VSCode-blue border glow */
.editor-container.mode-insert-active {
  animation: insert-breathe 2.5s ease-in-out infinite;
}

@keyframes insert-breathe {
  0%, 100% { box-shadow: inset 0 0 0 1px rgba(82, 139, 255, 0.18); }
  50%       { box-shadow: inset 0 0 0 1px rgba(82, 139, 255, 0.50), 0 0 16px rgba(82, 139, 255, 0.08); }
}

/* Arrow-key violation flash — red border pulse (L2+: arrowGuard levels) */
@keyframes arrow-flash {
  0%   { box-shadow: inset 0 0 0 2px rgba(244, 71, 71, 0); }
  18%  { box-shadow: inset 0 0 0 2px rgba(244, 71, 71, 0.95), 0 0 22px rgba(244, 71, 71, 0.30); }
  100% { box-shadow: inset 0 0 0 2px rgba(244, 71, 71, 0); }
}

.editor-container.arrow-flash {
  animation: arrow-flash 0.55s ease-out forwards !important;
}

/* The @uiw/react-codemirror wrapper div also needs to fill its parent */
.editor-container > div {
  flex: 1 1 0%;
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Force CodeMirror to fill its container (belt + suspenders alongside
   the EditorView.theme extension injected in App.tsx) */
.editor-container .cm-editor {
  flex: 1 1 0%;
  height: 100% !important;
  font-size: 13px;
  font-family: 'JetBrains Mono', 'SF Mono', 'Monaco', 'Menlo', 'Consolas', monospace;
  text-align: left !important;   /* never inherit center-align from outside */
}

/* ─── Content-only blur (entropy penalty, Bug 2 fix) ────────────────────── */
/* Blur is applied ONLY to the code content area, never to the gutter or
   line numbers. The --contentBlur CSS variable is set inline by App.tsx
   and is 0px for tutorial levels (L1-L4) and levels with low entropy. */
.editor-container .cm-content {
  filter: blur(var(--contentBlur, 0px));
  transition: filter 0.3s ease;
}

/* ─── Cursor: ghosting-free, VS Code blue ─────────────────────────────── */
/*
  Shape + color are handled by EditorView.theme injected in App.tsx.
  CSS here only handles blink behavior so we don’t fight the theme.

  Rule:
    • Normal mode (.cm-fat-cursor on editor root): NO blink, block cursor.
    • Insert mode                                : blink, thin 2px line.

  NEVER use `display:none` on `.cm-cursorLayer` — that removes the cursor
  entirely and causes the "invisible cursor" / ghost-cursor bugs.
*/

/* Stop blink in Normal mode — a static block never blinks */
.cm-editor.cm-fat-cursor .cm-cursorLayer {
  animation: none !important;
}

/* In Normal mode suppress every non-fat-cursor element (thin residuals).
   The fat-cursor widget itself keeps visibility:visible from the theme.   */
.cm-editor.cm-fat-cursor .cm-cursor:not(.cm-fat-cursor) {
  visibility: hidden !important;
}

/* ─── Ghost Cursor Target (Decoration.mark) ──────────────────────────────── */
/* Marks the target character with a teal highlight + animated glow.
   The selector must be specific enough to override the vscodeDark theme. */
.cm-editor .cm-ghost-target {
  background: rgba(78, 201, 176, 0.28);
  border-bottom: 2px solid rgba(78, 201, 176, 0.85);
  border-radius: 2px;
  animation: ghost-pulse 1.4s ease-in-out infinite;
  box-decoration-break: clone;
  -webkit-box-decoration-break: clone;
}

/* Ghost cursor widget (inline widget placed at target position) */
.cm-ghost-cursor-widget {
  display: inline-block;
  width: 0.6em;
  height: 1.2em;
  margin-right: -0.6em;
  background: #1d8effa5;
  border: none;
  border-radius: 2px;
  opacity: 1;
  animation: ghost-pulse 1.4s ease-in-out infinite;
  vertical-align: text-bottom;
  pointer-events: none;
}

@keyframes ghost-pulse {
  0%, 100% { opacity: 1.0; }
  50%       { opacity: 0.65; }
}

/* ─── Active Line ─────────────────────────────────────────────────────────── */
.cm-editor .cm-activeLine       { background: rgba(255,255,255,0.03) !important; }
.cm-editor .cm-activeLineGutter { background: rgba(255,255,255,0.03) !important; }

/* ─── Dashboard (fixed height bottom panel) ───────────────────────────────── */
.dashboard {
  height: 100%;      /* Panel controls the size; we just fill it */
  width: 100%;
  box-sizing: border-box;
  position: relative;    /* required: confetti canvas is absolute inside here */
  background: #121212;
  border-top: 1px solid #222;
  box-shadow: 0 -6px 18px rgba(0, 0, 0, 0.60);
  overflow: hidden;      /* clips confetti particles to panel zone */
}

.dashboard-inner {
  height: 100%;
  padding: 16px 24px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 8px;
  text-align: left;
}

/* ─── Level Header Row ───────────────────────────────────────────────────── */
.level-header {
  display: flex;
  align-items: center;
  gap: 10px;
}

.level-id {
  font-size: 11px;
  color: #858585;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  white-space: nowrap;
}

.level-keys {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  color: #1e1e1e;
  background: #4ec9b0;
  padding: 1px 8px;
  border-radius: 3px;
  letter-spacing: 1px;
  white-space: nowrap;
}

/* ─── Instruction ────────────────────────────────────────────────────────── */
.level-instruction {
  font-size: 18px;
  font-weight: 500;
  line-height: 1.6;
  color: #dde3ed;
  text-align: left;    /* left-align to match editor code indentation */
  flex: 1;
  overflow: auto;      /* scroll rather than clip if text is very long */
}

/* ─── Status Bar ─────────────────────────────────────────────────────────── */
.status-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 5px 10px;
  background: #0d0d0d;
  border-radius: 4px;
  font-size: 11.5px;
  min-width: 0;
}

.status-pos {
  color: #858585;
  font-variant-numeric: tabular-nums;
}

.status-pos strong {
  color: #d4d4d4;
}

/* Vim mode pill */
.status-mode {
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 1px 6px;
  border-radius: 3px;
  border: 1px solid transparent;
  transition: background 0.15s, color 0.15s;
}

.mode-normal  { color: #ce9178; border-color: rgba(206,145,120,.4); background: rgba(206,145,120,.1); }
.mode-insert  { color: #4ec9b0; border-color: rgba(78,201,176,.4);  background: rgba(78,201,176,.1);  }
.mode-visual  { color: #c586c0; border-color: rgba(197,134,192,.4); background: rgba(197,134,192,.1); }
.mode-replace { color: #f44747; border-color: rgba(244,71,71,.4);   background: rgba(244,71,71,.1);   }

.status-target {
  font-size: 11px;
  color: #4ec9b0;
  letter-spacing: 0.3px;
  animation: target-fade 2s ease-in-out infinite alternate;
}

/* Entropy counter pill */
.status-entropy {
  font-size: 11px;
  color: #4ec9b0;
  font-variant-numeric: tabular-nums;
  transition: color 0.3s;
}
.status-entropy.penalty { color: #f44747; }
.entropy-limit           { color: #555; }

/* Status bar right group: target + mode toggle */
.status-bar-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 10px;
}

/* Zen / Challenge mode toggle button */
.mode-toggle {
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.8px;
  padding: 1px 8px;
  border-radius: 3px;
  border: 1px solid rgba(133,133,133,0.35);
  background: rgba(133,133,133,0.07);
  color: #858585;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s, background 0.15s;
  font-family: inherit;
  white-space: nowrap;
}
.mode-toggle:hover {
  border-color: rgba(82,139,255,0.5);
  color: #aaaaaa;
}
.mode-toggle.active {
  border-color: rgba(244,71,71,0.45);
  background: rgba(244,71,71,0.08);
  color: #f44747;
}

@keyframes target-fade {
  from { opacity: 1; }
  to   { opacity: 0.55; }
}

/* ─── Success Flash Overlay ──────────────────────────────────────────────── */
.success-flash {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(13, 13, 13, 0.96);
  border: 1px solid #4ec9b0;
  border-radius: 8px;
  padding: 18px 40px;
  font-size: 20px;
  font-weight: 700;
  color: #4ec9b0;
  letter-spacing: 0.5px;
  z-index: 100;
  /* flash-in: 0.18s, hold for 0.75s, fade-out: 0.25s → total ≈ 1.18s */
  animation: flash-in 0.18s ease-out, flash-out 0.25s ease-in 0.75s forwards;
  pointer-events: none;
  box-shadow: 0 0 40px rgba(78, 201, 176, 0.30);
}

@keyframes flash-in {
  from { opacity: 0; transform: translate(-50%, -48%) scale(0.95); }
  to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}
@keyframes flash-out {
  to   { opacity: 0; transform: translate(-50%, -52%) scale(0.97); }
}

/* ─── Toast (anti-pattern warning) ──────────────────────────────────────── */
.toast {
  position: fixed;
  bottom: 160px;          /* just above the dashboard */
  left: 50%;
  transform: translateX(-50%);
  max-width: 480px;
  width: 90vw;
  background: #121212;
  border: 1px solid #ffd700;
  border-left: 4px solid #ffd700;
  border-radius: 6px;
  padding: 10px 16px;
  font-size: 12.5px;
  color: #ffd700;
  z-index: 99;
  pointer-events: none;
  animation: toast-in 0.2s ease-out, toast-out 0.3s ease-in 3.2s forwards;
  box-shadow: 0 4px 20px rgba(0,0,0,0.4);
}

@keyframes toast-in {
  from { opacity: 0; transform: translateX(-50%) translateY(8px); }
  to   { opacity: 1; transform: translateX(-50%) translateY(0); }
}
@keyframes toast-out {
  to   { opacity: 0; transform: translateX(-50%) translateY(4px); }
}

/* ─── Completion Toast (right-bottom, non-blocking level-clear notice) ────── */
.completion-toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  max-width: 380px;
  background: rgba(13, 13, 13, 0.95);
  border: 1px solid #4ec9b0;
  border-left: 4px solid #4ec9b0;
  border-radius: 6px;
  padding: 10px 16px;
  font-size: 12.5px;
  color: #4ec9b0;
  z-index: 99;
  pointer-events: none;        /* never steals editor focus */
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  animation: ctoa-in 0.2s ease-out, ctoa-out 0.3s ease-in 2.4s forwards;
}

@keyframes ctoa-in {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes ctoa-out {
  to   { opacity: 0; transform: translateY(6px); }
}

/* ─── Misc CodeMirror polish ─────────────────────────────────────────────── */
.cm-gutters {
  background: #0d0d0d !important;
  border-right: 1px solid #222 !important;
  min-width: 42px;
}

.cm-lineNumbers .cm-gutterElement {
  color: #858585;
  padding: 0 6px;
  min-width: 28px;
}

/* ─── Video demo modal ───────────────────────────────────────────────────── */
.video-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.78);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-modal {
  position: relative;
  width: min(640px, 92vw);
  background: #121212;
  border: 1px solid #333;
  border-radius: 8px;
  padding: 12px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.7);
}

.video-close {
  position: absolute;
  top: 8px;
  right: 10px;
  background: none;
  border: none;
  color: #858585;
  font-size: 16px;
  cursor: pointer;
  line-height: 1;
  transition: color 0.15s;
}
.video-close:hover { color: #d4d4d4; }

/* "▶ 大神操作" button in level-header */
.video-btn {
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.6px;
  padding: 1px 8px;
  border-radius: 3px;
  border: 1px solid rgba(82, 139, 255, 0.4);
  background: rgba(82, 139, 255, 0.08);
  color: #528bff;
  cursor: pointer;
  font-family: inherit;
  white-space: nowrap;
  transition: border-color 0.15s, background 0.15s;
}
.video-btn:hover {
  border-color: rgba(82, 139, 255, 0.7);
  background: rgba(82, 139, 255, 0.14);
}

/* ─── Command Sidebar ────────────────────────────────────────────────────────── */
.command-sidebar {
  height: 100%;
  overflow-y: auto;
  background: #0d0d0d;
  border-left: 1px solid #1e1e1e;
  scrollbar-width: thin;
  scrollbar-color: #2a2a2a transparent;
}

.sidebar-header {
  padding: 10px 14px;
  border-bottom: 1px solid #1e1e1e;
  font-size: 10px;
  color: #444;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cmd-group { padding-bottom: 4px; }

.cmd-group-label {
  padding: 8px 14px 3px;
  font-size: 9.5px;
  color: #3a3a3a;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

.cmd-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 5px 14px;
}
.cmd-row:hover { background: rgba(255,255,255,0.03); }

.vim-key {
  display: inline-block;
  min-width: 32px;
  text-align: center;
  background: #1a1a1a;
  border: 1px solid #383838;
  border-bottom: 2px solid #484848;
  border-radius: 4px;
  padding: 2px 6px;
  font-family: 'SF Mono', 'Monaco', 'Menlo', 'Consolas', monospace;
  font-size: 11px;
  color: #d4d4d4;
  white-space: nowrap;
  flex-shrink: 0;
}

.cmd-desc {
  font-size: 11.5px;
  color: #585858;
  line-height: 1.4;
}

.cmd-fallback {
  padding: 16px 14px;
  font-size: 13px;
  color: #858585;
  font-weight: 600;
  letter-spacing: 1px;
}

/* ═══════════════════════════════════════════════════════════════════════════
   SIDEBAR REDESIGN — Cyberpunk Geek aesthetic
   Primary neon:  #00e5cc  (cyan)
   Secondary:     #528bff  (electric blue, existing palette)
   ═══════════════════════════════════════════════════════════════════════════ */

/* Scoped CSS properties + inset ambient glow */
.command-sidebar {
  --sa:      #00e5cc;
  --sa-dim:  rgba(0, 229, 204, 0.10);
  --sa-glow: rgba(0, 229, 204, 0.22);
  --sa2:     #528bff;
  box-shadow: inset 0 0 60px rgba(0, 229, 204, 0.025);
}

/* ─── Level Card ─────────────────────────────────────────────────────────── */
.sidebar-level-card {
  margin: 12px 10px 8px;
  padding: 18px 16px 14px;
  background: #161616;
  border: 1px solid rgba(0, 229, 204, 0.14);
  border-left: 3px solid var(--sa);
  border-radius: 6px;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.03),
    0 2px 16px rgba(0, 229, 204, 0.06);
  display: flex;
  flex-direction: column;
  gap: 9px;
}

.sidebar-level-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sidebar-level-loc {
  display: flex;
  align-items: baseline;
  gap: 5px;
}

.sidebar-level-tag {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.4px;
  text-transform: uppercase;
  color: #383838;
}

/* Neon gradient big number */
.sidebar-level-num {
  font-size: 22px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.5px;
  background: linear-gradient(130deg, var(--sa) 0%, var(--sa2) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sidebar-level-total {
  font-size: 10px;
  color: #333;
}

/* Breathing ACTIVE badge */
.sidebar-active-badge {
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 1.6px;
  text-transform: uppercase;
  color: var(--sa);
  background: var(--sa-dim);
  border: 1px solid var(--sa-glow);
  border-radius: 3px;
  padding: 2px 7px;
  white-space: nowrap;
  animation: badge-breathe 2.8s ease-in-out infinite;
}

@keyframes badge-breathe {
  0%, 100% {
    opacity: 1;
    box-shadow: 0 0 4px rgba(0, 229, 204, 0.15);
  }
  50% {
    opacity: 0.55;
    box-shadow: 0 0 12px rgba(0, 229, 204, 0.40);
  }
}

/* Keys pill — neon solid background */
.sidebar-keys-badge {
  align-self: flex-start;
  font-size: 11px;
  font-weight: 700;
  font-family: 'SF Mono', 'Monaco', 'Menlo', 'Consolas', monospace;
  color: #0d0d0d;
  background: var(--sa);
  padding: 2px 10px;
  border-radius: 3px;
  letter-spacing: 1px;
  box-shadow: 0 0 10px var(--sa-glow);
}

/* Task description — scrollable, never truncated */
.sidebar-task-text {
  font-size: 15px;
  font-weight: 500;
  line-height: 1.65;
  color: #dde3ed;
  max-height: none;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: #2a2a2a transparent;
  margin: 0;
}

/* ─── Section separator label ────────────────────────────────────────────── */
.sidebar-section-label {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px 4px;
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #484858;
}

.sidebar-section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, #1e1e1e, transparent);
}

/* ─── Cheatsheet Grid ────────────────────────────────────────────────────── */
/* Each category gets its own grid wrapper (auto | 1fr) */
.sidebar-cheatsheet {
  display: grid;
  grid-template-columns: auto 1fr;
  padding: 0 10px 6px;
  row-gap: 2px;
}

.sidebar-cat-label {
  grid-column: 1 / -1;
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #CBD5E1;
  padding: 8px 6px 4px;
}

/* Entry row — spans both columns, defines inner 2-col grid for key + action */
.sidebar-key-entry-wrap {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: auto 1fr;
  align-items: center;
  gap: 10px;
  padding: 5px 6px;
  border-radius: 4px;
  border: 1px solid transparent;
  transition: background 0.12s, border-color 0.12s;
  cursor: default;
}

.sidebar-key-entry-wrap:hover {
  background: rgba(0, 229, 204, 0.04);
  border-color: rgba(0, 229, 204, 0.20);
}

/* Monospace key badge — warm near-white for maximum contrast */
.sidebar-key {
  font-family: 'SF Mono', 'Monaco', 'Menlo', 'Consolas', monospace;
  font-size: 11px;
  font-weight: 700;
  color: #FFFFFF;
  background: #1a1a1a;
  border: 1px solid #2e2e2e;
  border-bottom: 2px solid #3a3a3a;
  border-radius: 4px;
  padding: 2px 7px;
  min-width: 32px;
  text-align: center;
  white-space: nowrap;
  line-height: 1.5;
  transition: color 0.12s, border-color 0.12s;
}

.sidebar-key-entry-wrap:hover .sidebar-key {
  color: #ffffff;
  border-color: rgba(0, 229, 204, 0.45);
  border-bottom-color: rgba(0, 229, 204, 0.60);
}

.sidebar-action {
  font-size: 12.5px;
  font-weight: 500;
  line-height: 1.4;
  color: #E2E8F0;
  transition: color 0.12s;
}

.sidebar-key-entry-wrap:hover .sidebar-action {
  color: #a0a0b8;
}

/* ─── Resize Handles (react-resizable-panels) ────────────────────────────── */
/* Default: near-invisible dark seam. Hover/drag: subtle brightening only —
   no vivid colours, so the #0d0d0d atmosphere is fully preserved.           */
.resize-handle-v {
  width: 2px;
  background: #1c1c1c;
  cursor: col-resize;
  flex-shrink: 0;
  outline: none;
  transition: background 0.15s;
}

.resize-handle-h {
  height: 2px;
  background: #1c1c1c;
  cursor: row-resize;
  flex-shrink: 0;
  outline: none;
  transition: background 0.15s;
}

.resize-handle-v:hover,
.resize-handle-v[data-resize-handle-active],
.resize-handle-v[data-resize-handle-state="drag"],
.resize-handle-v[data-resize-handle-state="focus"],
.resize-handle-h:hover,
.resize-handle-h[data-resize-handle-active],
.resize-handle-h[data-resize-handle-state="drag"],
.resize-handle-h[data-resize-handle-state="focus"] {
  background: #383838;
}

/* ─── Responsive (narrow screens) ───────────────────────────────────────── */
@media (max-width: 600px) {
  .dashboard-inner      { padding: 8px 12px; }
  .level-instruction    { -webkit-line-clamp: 3; }
  .status-target        { display: none; }
  .command-sidebar      { display: none; }
  .resize-handle-v      { display: none; }
}

/* ─── Word-Motion Jump Ripple ─────────────────────────────────────────────── */
/* Fires on w / e / b keypress: a single 300 ms cyan edge-glow that fades out.
   Uses `forwards` fill so it ends cleanly rather than snapping back.          */
@keyframes word-jump-flash {
  0%   { box-shadow: inset 0 0 0 1px rgba(0, 229, 204, 0);   }
  20%  { box-shadow: inset 0 0 0 1px rgba(0, 229, 204, 0.55),
                     0 0 20px rgba(0, 229, 204, 0.10); }
  100% { box-shadow: inset 0 0 0 1px rgba(0, 229, 204, 0);   }
}

.editor-container.word-jump-active {
  animation: word-jump-flash 0.32s ease-out forwards !important;
}

/* ─── Action Counter pill (always-visible keystroke count) ───────────────── */
.status-steps {
  font-size: 11px;
  color: #858585;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3px;
}

/* 新增：左右拖拽布局样式 */
.app-container {
  height: 100vh;
  display: flex;
  overflow: hidden;
}

.custom-resizer {
  width: 4px;
  background-color: #1A1A1A;
  cursor: col-resize;
  transition: background-color 0.2s ease;
}

.custom-resizer:hover,
.custom-resizer:active {
  background-color: #333333;
}
